FROM ubuntu:18.04

ARG DEBIAN_FRONTEND=noninteractive
ARG USER_ID=1000
ARG GROUP_ID=1000

# Proxy
ARG http_proxy
ARG https_proxy
ARG ftp_proxy
ARG all_proxy
ARG no_proxy
ARG HTTP_PROXY
ARG HTTPS_PROXY
ARG FTP_PROXY
ARG ALL_PROXY
ARG NO_PROXY

# =============================================================================
# Ubuntu 18.04 — Embedded Linux build environment (Buildroot, Yocto, OpenWrt)
# =============================================================================

RUN set -eux; \
    HP="${http_proxy:-${HTTP_PROXY:-}}"; \
    HPS="${https_proxy:-${HTTPS_PROXY:-${HP:-}}}"; \
    if [ -n "${HP}" ] || [ -n "${HPS}" ]; then \
        printf 'Acquire::http::Proxy "%s";\nAcquire::https::Proxy "%s";\n' "${HP}" "${HPS}" > /etc/apt/apt.conf.d/99proxy; \
    fi; \
    echo 'Acquire::ForceIPv4 "true";' > /etc/apt/apt.conf.d/99force-ipv4; \
    echo "dash dash/sh boolean false" | debconf-set-selections; \
    dpkg-reconfigure -f noninteractive dash

RUN set -eux; \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        bison \
        build-essential \
        curl \
        device-tree-compiler \
        flex \
        gawk \
        gcc-multilib \
        gettext \
        git \
        help2man \
        libncurses5-dev \
        libnl-3-dev \
        libnl-route-3-dev \
        locales \
        libssl-dev \
        libxml-parser-perl \
        neovim \
        python \
        python3 \
        python3-distutils \
        python3-pip \
        python3-setuptools \
        rsync \
        subversion \
        sudo \
        swig \
        texinfo \
        time \
        unzip \
        vim \
        wget \
        xxd \
        zlib1g-dev \
    && rm -rf /var/lib/apt/lists/* \
    && rm -f /etc/apt/apt.conf.d/99proxy /etc/apt/apt.conf.d/99force-ipv4

RUN set -eux; \
    pip3 install --no-cache-dir \
        jsonschema \
        Mako \
        pyelftools \
        PyYAML \
        yamllint \
    && rm -rf /root/.cache/pip

RUN set -eux; \
    locale-gen en_US en_US.UTF-8

ENV LC_ALL="en_US.UTF-8" \
    LANG="en_US.UTF-8" \
    LC_CTYPE="en_US.UTF-8" \
    LC_NUMERIC="en_US.UTF-8"

RUN groupadd -g ${GROUP_ID} builder \
    || groupmod -n builder $(getent group ${GROUP_ID} | cut -d: -f1) && \
    useradd -l -u ${USER_ID} -g ${GROUP_ID} -m -s /bin/bash builder && \
    echo "builder ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

USER builder
WORKDIR /workspace

CMD ["/bin/bash"]
